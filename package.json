{
  "name": "papertrail",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc",
    "dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch --include 'server/**/*.ts' server/index.ts",
    "dev:typecheck": "tsc --noEmit --watch",
    "start": "node dist/server/index.js",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:client": "tsc -p client/tsconfig.json --noEmit",
    "typecheck:server": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "openai": "^6.39.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^7.2.7"
  }
}
